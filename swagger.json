{
  "openapi": "3.0.0",
  "info": {
    "title": "TripPlanner API",
    "version": "1.0.0",
    "description": "Documentația API pentru aplicația TripPlanner"
  },
  "servers": [
    {
      "url": "http://localhost:3001"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [ "Auth" ],
        "summary": "Înregistrare utilizator nou",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [ "name", "email", "password" ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "George"
                  },
                  "email": {
                    "type": "string",
                    "example": "george@test.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "parola123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Utilizator înregistrat cu succes" },
          "400": { "description": "Date invalide" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [ "Auth" ],
        "summary": "Autentificare utilizator",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [ "email", "password" ],
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "george@test.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "parola123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Autentificare reușită, returnează token" },
          "400": { "description": "Date incorecte" }
        }
      }
    },
    "/api/trips": {
      "get": {
        "tags": [ "Trips" ],
        "summary": "Obține toate călătoriile utilizatorului autentificat",
        "security": [ { "bearerAuth": [] } ],
        "responses": {
          "200": { "description": "Listă călătorii" }
        }
      },
      "post": {
        "tags": [ "Trips" ],
        "summary": "Creează o călătorie nouă",
        "security": [ { "bearerAuth": [] } ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [ "destination", "start_date", "end_date" ],
                "properties": {
                  "destination": {
                    "type": "string",
                    "example": "Maldive Luxury"
                  },
                  "start_date": {
                    "type": "string",
                    "example": "2026-08-01"
                  },
                  "end_date": {
                    "type": "string",
                    "example": "2026-08-10"
                  },
                  "preferences": {
                    "type": "object",
                    "properties": {
                      "hotel": {
                        "type": "string",
                        "example": "5 stele"
                      },
                      "transport": {
                        "type": "string",
                        "example": "avion"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Călătorie creată" },
          "400": { "description": "Validare eșuată" }
        }
      }
    },
    "/api/trips/{id}": {
      "get": {
        "tags": [ "Trips" ],
        "summary": "Obține detaliile unei călătorii",
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Detalii călătorie" },
          "404": { "description": "Nu a fost găsită" }
        }
      },
      "put": {
        "tags": [ "Trips" ],
        "summary": "Actualizează o călătorie existentă",
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "destination": {
                    "type": "string",
                    "example": "Maldive Luxury"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Actualizată cu succes" }
        }
      },
      "delete": {
        "tags": [ "Trips" ],
        "summary": "Șterge o călătorie",
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Ștearsă cu succes" }
        }
      }
    },
    "/api/trips/{id}/days/{dayId}": {
      "put": {
        "tags": [ "Trips" ],
        "summary": "Editare manuală a unei zile dintr-o călătorie",
        "security": [ { "bearerAuth": [] } ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "ID-ul călătoriei",
            "schema": { "type": "integer" }
          },
          {
            "name": "dayId",
            "in": "path",
            "required": true,
            "description": "ID-ul unic al zilei din tabelul days",
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "morning": {
                    "type": "string",
                    "example": "Mic dejun la hotel"
                  },
                  "afternoon": {
                    "type": "string",
                    "example": "Vizită Turnul Eiffel"
                  },
                  "evening": {
                    "type": "string",
                    "example": "Cină romantică"
                  },
                  "activities": {
                    "type": "string",
                    "example": "Plan general alternativ"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Ziua a fost actualizată parțial cu succes folosind COALESCE" },
          "404": { "description": "Ziua nu există sau nu aparține trip-ului / utilizatorului" }
        }
      }
    }
  }
}